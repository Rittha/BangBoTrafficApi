{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PlcSettings": {
    "IpAddress": "192.168.1.10", //ต้องเปลี่ยนเป็น IP ของ PLC ที่ต้องการเชื่อมต่อ
    "Port": "502"  //พอร์ตที่ใช้สำหรับการเชื่อมต่อกับ PLC (โดยทั่วไปคือ 502 สำหรับ Modbus TCP)
  }
}